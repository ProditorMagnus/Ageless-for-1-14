#: .\units\EoM_units\therians\x3_Master.cfg:18
msgid "A master magician is a force to be reckoned with."
msgstr ""

#. [unit_type], id=AE_myh_Therian_Priest, race=AE_myh_therian
#. [unit_type], id=AE_mrc_holy_order_Priest, race=AE_mrc_holy_order_race, gender=male
#: .\units\EoM_units\therians\x3_Priest.cfg:5
#: .\units\ME_units\holy_order\b2-priest.cfg:5

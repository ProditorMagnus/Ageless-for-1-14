#. [unit_type], id=AE_arc_south_seas_Shoreman, race=AE_arc_race_south_seas_human, gender=male
#: .\units\archaic_units\south-seas\Shoreman.cfg:4
msgid "Shoreman"
msgstr ""

#. [unit_type], id=AE_arc_south_seas_Shoreman, race=AE_arc_race_south_seas_human, gender=male
#: .\units\archaic_units\south-seas\Shoreman.cfg:22
msgid ""
"The Shoremen are responsible for loading ships and breaking down retired "
"vessals to reclaim the components. Almost all of this work involves ropes, so"
" the Shoremen are very skilled with this simple tool and can tie down even "
"moving animals. A spike is very helpful in making splices, as well as killing"
" rats."
msgstr ""

#. [unit_type], id=AE_arc_south_seas_Sky_Caller, race=AE_arc_race_south_seas_human, gender=female
#: .\units\archaic_units\south-seas\Sky-Caller.cfg:4
msgid "female^Sky-Caller"
msgstr ""


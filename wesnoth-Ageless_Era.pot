msgstr ""

#. [unit_type], id=AE_arc_primeval_Cutter, race=AE_arc_race_primeval, gender=female
#: .\units\archaic_units\primeval\Primeval_Cutter.cfg:24
msgid ""
"Primeval Cutters are not particularly strong, but they can launch cutting "
"metal discs. Cutters are able to provide a counter to enemy archers.\n"
"Special Note:"
msgstr ""


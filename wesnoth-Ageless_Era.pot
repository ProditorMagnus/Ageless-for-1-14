#. [unit_type], id=AE_arc_south_seas_Swimmer, race=AE_arc_race_south_seas_human
#: .\units\archaic_units\south-seas\Swimmers.cfg:31
msgid ""
"Swimmers are sometimes employed on ships, but they are mostly located near "
"the villages, where they hunt fish for food, gather pearls for trade, and "
"patrol the docked ships."
msgstr ""

#. [female]
#: .\units\archaic_units\south-seas\Swimmers.cfg:90
msgid "female^Swimmer"
msgstr ""

#. [unit_type], id=AE_arc_south_seas_Wind_Caller, race=AE_arc_race_south_seas_human, gender=female
#: .\units\archaic_units\south-seas\Wind-Caller.cfg:4
msgid "female^Wind-Caller"
msgstr ""

#. [unit_type], id=AE_arc_south_seas_Wind_Caller, race=AE_arc_race_south_seas_human, gender=female
#: .\units\archaic_units\south-seas\Wind-Caller.cfg:18
msgid ""
"The Wind-Callers study the lore of the brighter gods. They pray for "
"favourable winds and a minimum of strife. They are successful at directing "
"wind-lashes, but the effort requires strength."
msgstr ""

#. [unit_type], id=AE_arc_south_seas_Breeze, race=undead, gender=male
#: .\units\archaic_units\south-seas\Wind_Breeze.cfg:5

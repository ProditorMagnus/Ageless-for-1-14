msgstr ""

#. [race], id=AE_myh_warg
#: .\units\EoM_units\warg.cfg:18
msgid "race^Warg"
msgstr ""

#. [race], id=AE_myh_warg
#: .\units\EoM_units\warg.cfg:19
msgid "race+female^Warg"
msgstr ""

#. [race], id=AE_myh_warg
#: .\units\EoM_units\warg.cfg:20
msgid "race^Wargs"
msgstr ""

#. [race], id=AE_myh_warg
#: .\units\EoM_units\warg.cfg:25
msgid ""
"Wargs are also known as wolfmen. They live in the wilds and woods in almost "
"any climate, some favor the lush jungle, others the arctic woods, others "
"alpine mountains. The warg tend to live in packs or clans, and establish "
"their hunting grounds where they tend not to like intruders. Although "
"hunters, they are for the most part peaceful, however they have a primal "
"blood-lust, that can be inspired by various things, especially if vampires "
"are involved."
msgstr ""

#. [race], id=AE_myh_abstraction
#: .\units\EoM_units\windsong.cfg:7

msgid "unholy missile"
msgstr ""

#. [unit_type], id=AE_arc_phantom_Feather_Dancer, race=AE_arc_race_phantom_egypt, gender=female
#: .\units\archaic_units\phantom\Tomb_Feather.cfg:4
msgid "Feather Dancer"
msgstr ""

#. [unit_type], id=AE_arc_phantom_Feather_Dancer, race=AE_arc_race_phantom_egypt, gender=female
#: .\units\archaic_units\phantom\Tomb_Feather.cfg:19
msgid ""
"These shades were adherents of a ceremonial combat style. They are able to "
"move with a confusing grace which makes them difficult hem in."
msgstr ""

#. [unit_type], id=AE_arc_phantom_Tomb_Guard, race=AE_arc_race_phantom_egypt
#: .\units\archaic_units\phantom\Tomb_Guardian.cfg:4
msgid "Tomb Guard"
msgstr ""

#. [unit_type], id=AE_arc_phantom_Tomb_Guard, race=AE_arc_race_phantom_egypt
#: .\units\archaic_units\phantom\Tomb_Guardian.cfg:17
msgid ""
"The tombs of the Astragartan Empire were tended to by a type of monk charged "
"with both preparing the bodies for the afterlife and providing defense "
"against any physical assault on the Astragarten legacy. Under some "
"conditions, these monks can bring slain foes under the sway of their "
"forgotten spirituality."
msgstr ""

#. [attack], type=cold, range=ranged
#. [attack], type=arcane, range=ranged
#: .\units\archaic_units\phantom\Tomb_Guardian.cfg:109
#: .\units\archaic_units\phantom\Tomb_Protector.cfg:133
#: .\units\archaic_units\phantom\Tomb_Sentinel.cfg:108
#: .\units\archaic_units\phantom\Tomb_Shield.cfg:97

#. [unit_type], id=AE_bem_wood_warriors_Bigfoot, race=AE_bem_wood_warriors_race
#. [unit_type], id=AE_bem_wood_warriors_Terrible_Bigfoot, race=AE_bem_wood_warriors_race
#. [unit_type], id=AE_bem_wood_warriors_Young_Bigfoot, race=AE_bem_wood_warriors_race

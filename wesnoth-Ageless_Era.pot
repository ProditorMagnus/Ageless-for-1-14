msgstr ""

#. [unit_type], id=AE_arc_phantom_High_Archer, race=AE_arc_race_phantom_egypt, gender=female
#: .\units\archaic_units\phantom\Tomb_HighArcher.cfg:4
msgid "High Archer"
msgstr ""

#. [attack], type=arcane, range=ranged
#: .\units\archaic_units\phantom\Tomb_HighArcher.cfg:105
msgid "blessed missile"
msgstr ""

#. [unit_type], id=AE_arc_phantom_Huntress, race=AE_arc_race_phantom_egypt, gender=female
#. [unit_type], id=AE_efm_whites_Huntress, race=AE_efm_whites, gender=female
#. [unit_type], id=AE_ele_Centaur_Huntress, race=AE_ele_centaur, gender=female
#: .\units\archaic_units\phantom\Tomb_Huntress.cfg:4

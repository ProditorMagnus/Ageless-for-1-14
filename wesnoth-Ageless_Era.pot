#. [unit_type], id=AE_ext_orcs_Orcish_Shaman, race=orc
#: .\units\EE_units\orcs\a1-Shaman.cfg:5
msgid "Orcish Shaman"
msgstr ""

#. [unit_type], id=AE_ext_orcs_Orcish_Shaman, race=orc
#: .\units\EE_units\orcs\a1-Shaman.cfg:18
msgid ""
"Orcish Shamans are the guardians of orcish magic. Respected among orcish "
"tribes, they form the Orcish Council, which makes important decisions for the"
" whole Orcish community and arbitrates the many conflicts that arise between "
"tribes of this argumentative race. Although physically weak (for Orcs), "
"Orcish Shamans are good spell casters and can curse their enemies, draining "
"their life."
msgstr ""

#. [unit_type], id=AE_ext_orcs_Orcish_Elder, race=orc
#: .\units\EE_units\orcs\a2-Elder.cfg:5
msgid "Orcish Elder"
msgstr ""

#. [unit_type], id=AE_ext_orcs_Orcish_Council_Member, race=orc
#: .\units\EE_units\orcs\a3-Council_Member.cfg:5
msgid "Orcish Council Member"
msgstr ""

#. [unit_type], id=AE_ext_orcs_Goblin_Cavalryman, race=wolf
#: .\units\EE_units\orcs\Cavalryman.cfg:4
msgid "Goblin Cavalryman"
msgstr ""

#. [unit_type], id=AE_ext_orcs_Hellwolf_Rider, race=wolf
#: .\units\EE_units\orcs\Hellwolf_Rider.cfg:4
msgid "Hellwolf Rider"
msgstr ""

#. [unit_type], id=AE_ext_orcs_Goblin_Lancer, race=wolf

msgid ""
"Therians who decide to do battle magics tend to have a pretty even match of "
"mastery between methods."
msgstr ""

#. [unit_type], id=AE_myh_Therian_Shaman, race=AE_myh_therian
#: .\units\EoM_units\therians\x2_Shaman.cfg:17
msgid ""
"The more spirital apprentices become shamans and spend much time learning how"
" to heal. Their training with offensive magics lags behind, and advances in "
"different ways."
msgstr ""

#. [unit_type], id=AE_myh_Therian_Master, race=AE_myh_therian
#. [unit_type], id=AE_mrc_oracles_Master, race=AE_mrc_oracles_race, gender=male

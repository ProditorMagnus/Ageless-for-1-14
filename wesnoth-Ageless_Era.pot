#: .\units\EOS_units\saurians\Duelist.cfg:17
#: .\units\EOS_units\saurians\Saurian_Skirmisher.cfg:10
msgid ""
"This unit is from The Era of Strife. Its coding and art were done by Jami, "
"AI, Elrias, Lizard, Quietus, Espreon, Neorice and Various others."
msgstr ""

#. [attack], type=blade, range=melee
#: .\units\EOS_units\saurians\Champion.cfg:26
#: .\units\EOS_units\saurians\Duelist.cfg:27

msgstr ""

#. [resistance], id=AE_chs_sustenance
#: .\data\EoC_data\abilities.cfg:227
msgid ""
"This unit’s resistances are increased by 20% in daylight, on defense and "
"attack. Vulnerabilities are not affected."
msgstr ""


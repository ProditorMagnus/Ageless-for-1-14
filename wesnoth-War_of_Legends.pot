#. [unit_type], id=AE_agl_steelhive_Rocketer, race=AE_agl_steelhive, gender=female
#: .\units\misc_units\steelhive\steel_impaler.cfg:4
msgid "Steel Rocketer"
msgstr ""

#. [unit_type], id=AE_agl_steelhive_Rocketer, race=AE_agl_steelhive, gender=female
#: .\units\misc_units\steelhive\steel_impaler.cfg:17
msgid ""
"This unit art and code is from Steel Hive - War of Legends Era, redesigned as"
" custom unit by IPS to fit AE - Steelhive faction.\n"
"\n"
"Rocketers use modern high accuracy rockets to fire at distant targets. "
"They're excelent at dealing againist garrisoned units and they deal high "
"physical damage at distance but they have to be covered carefully as they "
"cannot retaliate in melee range."
msgstr ""

#. [unit_type], id=AE_agl_steelhive_Bombardier, race=AE_agl_steelhive, gender=female
